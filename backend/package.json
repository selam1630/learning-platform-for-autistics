{
  "name": "ethiopia-autism-support-backend",
  "version": "1.0.0",
  "description": "Backend API for the Ethiopia Autism Learning & Support App",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "mongo:rs:start": "bash scripts/start-local-mongo-rs.sh",
